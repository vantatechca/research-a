# Database
DATABASE_URL=postgresql://peptidebrain:peptidebrain_dev@localhost:5432/peptidebrain

# Redis
REDIS_URL=redis://localhost:6379/0

# AI - Claude (for Brain chat)
ANTHROPIC_API_KEY=sk-ant-...

# AI - OpenRouter (for cheap model bulk processing)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=deepseek/deepseek-chat

# YouTube Data API v3
YOUTUBE_API_KEY=

# Search API (SerpAPI or Serper.dev or Brave)
SERP_API_KEY=
SERP_API_PROVIDER=serper  # serper, serpapi, brave

# Etsy Open API
ETSY_API_KEY=

# Embeddings (OpenAI-compatible for pgvector)
EMBEDDINGS_API_KEY=
EMBEDDINGS_API_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small

# Worker API (internal — Next.js → FastAPI)
WORKER_API_URL=http://localhost:8000

# Shared bearer token for Next.js → FastAPI calls. MUST match the same env
# var on the peptidebrain-api service. Without this, /api/scrape/trigger
# returns 503 and cannot reach the worker.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKER_API_TOKEN=

# Next.js public
NEXT_PUBLIC_APP_NAME=PeptideBrain
